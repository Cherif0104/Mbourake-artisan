# Variables d'environnement Supabase
# Copiez ce fichier en .env et remplissez les valeurs

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# URL canonique du site (pour partage de liens - ex: https://mbourake.com)
# Si non défini, utilise https://mbourake.com en production
# VITE_APP_URL=https://mbourake.com

# Cloudinary (contournement bug Supabase Storage 500 - colonne level manquante)
# Créez un "Upload preset" unsigned dans Cloudinary > Paramètres > Upload
# VITE_CLOUDINARY_CLOUD_NAME=drtcp8ewv
# VITE_CLOUDINARY_UPLOAD_PRESET=votre_preset_unsigned

# Optionnel : URL de l'APK Android pour téléchargement direct (hors Play Store).
# Si non défini, le site utilise /download/mbourake.apk (fichier dans public/download/).
# VITE_ANDROID_APK_URL=https://exemple.com/mbourake.apk
